{
  "name": "backend",
  "version": "1.0.0",
  "description": "AI-Powered Quiz Learning System Backend",
  "main": "src/app.js",
  "scripts": {
    "start": "node src/app.js",
    "dev": "nodemon src/app.js",
    "db:migrate": "npx sequelize-cli db:migrate --migrations-path src/database/migrations --config src/config/config.js",
    "db:seed": "npx sequelize-cli db:seed:all --seeders-path src/database/seeders --config src/config/config.js",
    "db:reset": "npx sequelize-cli db:migrate:undo:all --migrations-path src/database/migrations --config src/config/config.js && npm run db:migrate && npm run db:seed",
    "test": "echo \"Error: no test specified\" && exit 1"
  },
  "keywords": [],
  "author": "",
  "license": "ISC",
  "dependencies": {
    "@google/generative-ai": "^0.24.1",
    "@supabase/supabase-js": "^2.105.1",
    "axios": "^1.13.6",
    "bcryptjs": "^3.0.3",
    "cheerio": "^1.2.0",
    "cors": "^2.8.5",
    "dotenv": "^16.6.1",
    "express": "^4.21.2",
    "helmet": "^8.0.0",
    "joi": "^18.1.1",
    "jsonwebtoken": "^9.0.3",
    "mammoth": "^1.12.0",
    "morgan": "^1.10.0",
    "multer": "^2.1.1",
    "mysql2": "^3.12.0",
    "nodemailer": "^8.0.4",
    "pdf-parse": "^2.4.5",
    "sequelize": "^6.37.5",
    "socket.io": "^4.8.3",
    "socket.io-client": "^4.8.3"
  },
  "devDependencies": {
    "nodemon": "^3.1.9",
    "sequelize-cli": "^6.6.5"
  }
}
